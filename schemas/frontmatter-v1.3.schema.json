{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wage-wiki.local/schemas/frontmatter-v1.3.schema.json",
  "title": "Wage Wiki entity frontmatter v1.3",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "entity_type",
    "title",
    "jurisdiction",
    "status",
    "legal_status",
    "ingestion_status",
    "aliases",
    "id_aliases",
    "primary_authority",
    "primary_authority_id",
    "authority_ids",
    "authority_level",
    "enforcement_weight",
    "effective_from",
    "effective_to",
    "as_of_date",
    "review_cycle",
    "source_urls",
    "evidence",
    "relations",
    "last_checked",
    "last_verified",
    "last_updated",
    "verified_by"
  ],
  "properties": {
    "schema_version": {"const": "1.3"},
    "id": {"type": "string", "minLength": 1, "pattern": "^(?!(?:claim|evidence|source):)[^\\s]+$"},
    "entity_type": {
      "enum": ["concept", "rule", "case", "law", "interpretation", "history", "discussion", "fact_pattern"]
    },
    "title": {"type": "string", "minLength": 1},
    "jurisdiction": {"const": "KR"},
    "status": {"enum": ["draft", "review", "verified"]},
    "legal_status": {"enum": ["current", "historical", "superseded", "overruled", "future", "unknown"]},
    "ingestion_status": {"enum": ["imported", "extracted", "linked", "verified"]},
    "aliases": {"$ref": "#/$defs/stringArray"},
    "id_aliases": {"$ref": "#/$defs/stringArray"},
    "primary_authority": {"type": "string"},
    "primary_authority_id": {"type": "string"},
    "authority_ids": {"$ref": "#/$defs/stringArray"},
    "authority_level": {"type": "integer", "minimum": 1, "maximum": 7},
    "enforcement_weight": {"enum": ["critical", "high", "medium", "low"]},
    "conflict_status": {"enum": ["none", "active"]},
    "conflict_type": {"enum": ["none", "authority", "temporal", "interpretive", "jurisdictional"]},
    "conflict_resolution": {"enum": ["", "pending", "resolved", "unresolvable"]},
    "conflict_resolution_note": {"type": "string"},
    "conflict_resolved_date": {"$ref": "#/$defs/optionalDate"},
    "effective_from": {"$ref": "#/$defs/date"},
    "effective_to": {"$ref": "#/$defs/date"},
    "as_of_date": {"$ref": "#/$defs/date"},
    "superseded_by": {"type": "string"},
    "superseded_date": {"$ref": "#/$defs/optionalDate"},
    "review_cycle": {"enum": ["monthly", "quarterly", "annual"]},
    "review_trigger": {"$ref": "#/$defs/stringArray"},
    "related_concepts": {"$ref": "#/$defs/stringArray"},
    "related_rules": {"$ref": "#/$defs/stringArray"},
    "related_cases": {"$ref": "#/$defs/stringArray"},
    "related_laws": {"$ref": "#/$defs/stringArray"},
    "related_interpretations": {"$ref": "#/$defs/stringArray"},
    "related_fact_patterns": {"$ref": "#/$defs/stringArray"},
    "related_raw": {"$ref": "#/$defs/stringArray"},
    "source_excerpt": {"$ref": "#/$defs/stringArray"},
    "source_urls": {
      "type": "array",
      "items": {"type": "string", "pattern": "^https?://"},
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "relations": {
      "type": "array",
      "items": {"$ref": "#/$defs/relation"}
    },
    "last_checked": {"$ref": "#/$defs/optionalDate"},
    "last_verified": {"$ref": "#/$defs/optionalDate"},
    "last_updated": {"$ref": "#/$defs/date"},
    "verified_by": {"$ref": "#/$defs/stringArray"},
    "verification": {"$ref": "#/$defs/verificationMetadata"},
    "court_name": {"type": "string"},
    "case_number": {"type": "string"},
    "case_numbers": {"$ref": "#/$defs/stringArray"},
    "decision_date": {"$ref": "#/$defs/optionalDate"},
    "case_role": {"enum": ["leading", "persuasive", "conflicting", "overruling"]},
    "holding_summary": {"type": "string"},
    "legal_principles": {"$ref": "#/$defs/stringArray"},
    "source_availability": {"enum": ["available", "unavailable_official", "partial"]},
    "source_availability_note": {"type": "string"},
    "rule_type": {"enum": ["inclusion", "exclusion", "calculation", "limitation", "procedure"]},
    "issue": {"type": "string", "minLength": 1},
    "elements": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
    "exceptions": {"$ref": "#/$defs/stringArray"},
    "conclusion": {"type": "string", "minLength": 1},
    "temporal": {"$ref": "#/$defs/temporal"},
    "law_version": {"type": "string", "minLength": 1},
    "law_revision_date": {"$ref": "#/$defs/optionalDate"},
    "wage_criteria": {
      "type": "array",
      "items": {
        "enum": ["정기성", "일률성", "소정근로대가성", "근로대가성", "계속성", "정기지급성", "사전확정성", "고정성"]
      },
      "uniqueItems": true
    },
    "decision_factors": {"$ref": "#/$defs/stringArray"},
    "wage_type": {
      "type": "array",
      "items": {"enum": ["임금", "통상임금", "평균임금", "최저임금", "비과세"]},
      "uniqueItems": true
    },
    "worker_scope": {"type": "string"},
    "calculation_unit": {"type": "string"},
    "extinction_period": {"type": "string", "minLength": 1},
    "promulgation_date": {"$ref": "#/$defs/optionalDate"},
    "enforcement_date": {"$ref": "#/$defs/optionalDate"},
    "issuing_agency": {"type": "string"},
    "document_number": {"type": "string"},
    "issue_date": {"$ref": "#/$defs/optionalDate"},
    "interpretation_type": {"enum": ["guideline", "official_reply", "directive", "notice", "manual"]},
    "legal_effect": {"enum": ["binding_internal", "persuasive", "informational"]}
  },
  "allOf": [
    {
      "if": {"properties": {"entity_type": {"const": "case"}}, "required": ["entity_type"]},
      "then": {
        "required": ["court_name", "case_number", "decision_date", "case_role", "holding_summary", "legal_principles", "source_availability", "source_availability_note"]
      }
    },
    {
      "if": {"properties": {"entity_type": {"const": "rule"}}, "required": ["entity_type"]},
      "then": {
        "required": ["rule_type", "issue", "elements", "exceptions", "conclusion", "temporal", "wage_criteria", "decision_factors", "wage_type", "worker_scope", "calculation_unit", "extinction_period"]
      }
    },
    {
      "if": {"properties": {"entity_type": {"const": "law"}}, "required": ["entity_type"]},
      "then": {"required": ["law_version", "law_revision_date", "promulgation_date", "enforcement_date"]}
    },
    {
      "if": {"properties": {"entity_type": {"const": "interpretation"}}, "required": ["entity_type"]},
      "then": {"required": ["issuing_agency", "document_number", "issue_date", "interpretation_type", "legal_effect"]}
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "optionalDate": {"type": "string", "pattern": "^(|[0-9]{4}-[0-9]{2}-[0-9]{2})$"},
    "stringArray": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence": {
      "type": "object",
      "required": ["evidence_id", "source_id", "locator", "supports"],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1, "pattern": "^(?!\\s*$)\\S(?:.*\\S)?$"},
        "source_id": {"type": "string", "minLength": 1, "pattern": "^(?!\\s*$)\\S(?:.*\\S)?$"},
        "locator": {"type": "string", "minLength": 1, "pattern": "^(?!\\s*$)\\S(?:.*\\S)?$"},
        "excerpt": {"type": "string"},
        "supports": {"type": "array", "items": {"$ref": "#/$defs/claimId"}, "minItems": 1, "uniqueItems": true},
        "verified_on": {"$ref": "#/$defs/optionalDate"}
      },
      "additionalProperties": false
    },
    "claimId": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "verifierId": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "verificationMetadata": {
      "type": "object",
      "required": ["verifier_ids", "methods", "note"],
      "properties": {
        "verifier_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/verifierId"},
          "uniqueItems": true
        },
        "methods": {
          "type": "array",
          "items": {"enum": ["official_source_review", "source_cross_check"]},
          "uniqueItems": true
        },
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": ["relation_type", "target_id"],
      "properties": {
        "relation_type": {
          "enum": ["establishes", "applies", "interprets", "distinguishes", "overrules", "supersedes", "conflicts_with", "exception_to", "illustrated_by", "supports", "cites", "amends", "implements"]
        },
        "target_id": {"type": "string", "minLength": 1, "pattern": "^(?!\\s*$)\\S(?:.*\\S)?$"},
        "target": {"type": "string"},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "temporal": {
      "type": "object",
      "required": ["applicable_from", "applicable_to", "rule_version", "transition_note"],
      "properties": {
        "applicable_from": {"$ref": "#/$defs/date"},
        "applicable_to": {"$ref": "#/$defs/date"},
        "rule_version": {"type": "string", "minLength": 1},
        "transition_note": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
